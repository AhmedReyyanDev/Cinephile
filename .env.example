# Copy this file to .env and fill in your free API keys.
# Both keys are free to obtain.

# The Movie Database (required) -> https://www.themoviedb.org/settings/api
EXPO_PUBLIC_TMDB_API_KEY=

# OMDB (optional, adds IMDb / Rotten Tomatoes / Metacritic ratings)
# Get a free key -> https://www.omdbapi.com/apikey.aspx
EXPO_PUBLIC_OMDB_API_KEY=
